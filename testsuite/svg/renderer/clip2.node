mask {
  source: rounded-clip {
    clip: 30 30 40 40 / 20;
    child: color {
      bounds: 30 30 40 40;
      color: rgb(255,0,0);
    }
  }
  mask: container {
    fill {
      child: color {
        bounds: 0 0 50 50;
        color: rgb(0,0,0);
      }
      path: 0 0 50 50;
      fill-rule: winding;
    }
    fill {
      child: color {
        bounds: 50 50 50 50;
        color: rgb(0,0,0);
      }
      path: 50 50 50 50;
      fill-rule: winding;
    }
  }
}
